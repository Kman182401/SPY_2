# --- Databento ---
DATABENTO_API_KEY=REPLACE_ME

# --- IBKR paper ---
IBKR_HOST=127.0.0.1
IBKR_PORT_PAPER=4002
IBKR_CLIENT_ID=10

# --- Runtime mode ---
SPY2_MODE=DRY_RUN
LIVE_TRADING=false

# --- Data root ---
SPY2_DATA_ROOT=/mnt/bulk/spy2_data

# --- Fees/ticks (configure to IBKR schedule) ---
# Commission tiers are based on option premium (USD per share). Verify for your
# account/tier.
SPY2_IBKR_COMM_CUTOFF_1=0.05
SPY2_IBKR_COMM_RATE_1=0.25
SPY2_IBKR_COMM_CUTOFF_2=0.10
SPY2_IBKR_COMM_RATE_2=0.50
SPY2_IBKR_COMM_RATE_3=0.65

# Legacy single-rate commission fallback (used if tier keys are omitted).
SPY2_IBKR_PER_CONTRACT=0.65
SPY2_IBKR_MIN_PER_LEG=1.00
SPY2_IBKR_REG_PER_CONTRACT=0.04875
SPY2_IBKR_TRANS_PER_CONTRACT=0.00329
SPY2_IBKR_SEC_FEE_RATE=0.0
SPY2_IBKR_CONTRACT_MULTIPLIER=100
SPY2_TICK_SIZE_DEFAULT=0.01
SPY2_TICK_SIZE_SPY=0.01
